{
  "name": "vaultspace",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "description": "Open-source, self-hosted secure Virtual Data Room (VDR) platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/valcros/vaultspace.git"
  },
  "scripts": {
    "dev": "next dev",
    "dev:standalone": "DEPLOYMENT_MODE=standalone next dev",
    "build": "next build",
    "start": "next start",
    "start:standalone": "DEPLOYMENT_MODE=standalone next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:standalone": "DEPLOYMENT_MODE=standalone vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "mcp:playwright": "playwright-mcp --config ./playwright.mcp.config.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "DEPLOYMENT_MODE=standalone prisma migrate dev",
    "db:push": "DEPLOYMENT_MODE=standalone prisma db push",
    "db:seed": "prisma db seed",
    "db:reset": "DEPLOYMENT_MODE=standalone prisma migrate reset",
    "db:studio": "DEPLOYMENT_MODE=standalone prisma studio",
    "db:backup": "tsx scripts/backup.ts",
    "db:restore": "tsx scripts/restore.ts",
    "gdpr:export": "tsx scripts/gdpr-export.ts",
    "worker": "tsx src/workers/index.ts",
    "worker:standalone": "DEPLOYMENT_MODE=standalone tsx src/workers/index.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1009.0",
    "@azure/communication-email": "^1.1.0",
    "@azure/identity": "^4.13.0",
    "@azure/storage-blob": "^12.31.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.25.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "dxf-parser": "^1.1.2",
    "highlight.js": "^11.11.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.460.0",
    "markdown-it": "^14.1.1",
    "next": "^14.2.35",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.16",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^2.2.3",
    "react-pdf": "^9.1.1",
    "react-virtuoso": "^4.18.4",
    "recharts": "^2.13.3",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^5.1.1",
    "uuid": "^11.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.9.1",
    "@types/nodemailer": "^6.4.16",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-grid-layout": "^1.3.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "postcss": "^8.4.49",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
