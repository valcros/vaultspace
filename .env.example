# ============================================================================
# VaultSpace Environment Configuration
# ============================================================================
# VaultSpace supports two deployment modes.
# Default is Azure mode. Set DEPLOYMENT_MODE=standalone for self-hosted or local development.
#
# Copy this file to .env and configure the mode you are using.

# ============================================================================
# CORE APPLICATION
# ============================================================================

# Runtime environment: production or development
NODE_ENV=production

# Deployment mode: azure (default) or standalone
DEPLOYMENT_MODE=azure

# Full public URL (must include protocol and domain, no trailing slash)
# REQUIRED: Set to your Azure deployment URL
APP_URL=https://your-app.azurecontainerapps.io

# Session secret (generate: openssl rand -base64 32)
SESSION_SECRET=your-random-secret-here-change-in-production

# Application display names
APP_NAME=VaultSpace
DEFAULT_ORG_NAME=My Organization

# Logging level: info, debug, warn, error
LOG_LEVEL=info

# ============================================================================
# DATABASE (Azure PostgreSQL Required)
# ============================================================================

# Azure PostgreSQL connection string
# REQUIRED: Must point to Azure Database for PostgreSQL
# Format: postgresql://[user[:password]@][host][:port][/dbname]?sslmode=require
DATABASE_URL=postgresql://vaultspace@yourserver:password@yourserver.postgres.database.azure.com:5432/vaultspace?sslmode=require

# Connection pool size (app: 10-20, workers: 3-5)
DATABASE_POOL_SIZE=10

# ============================================================================
# REDIS (Azure Cache for Redis Required)
# ============================================================================

# Azure Cache for Redis connection string
# REQUIRED: Must point to Azure Cache for Redis
# Format: rediss://[:password@]yourserver.redis.cache.windows.net:6380
REDIS_URL=rediss://:your-access-key@yourserver.redis.cache.windows.net:6380

# Enable TLS for Redis (required for Azure Cache for Redis)
REDIS_TLS=true

# ============================================================================
# STORAGE (Azure Blob Storage Required)
# ============================================================================

# Storage backend: azure (local and s3 not supported in Azure-only mode)
STORAGE_PROVIDER=azure

# Azure Blob Storage configuration (REQUIRED)
STORAGE_BUCKET=vaultspace
AZURE_STORAGE_ACCOUNT=yourstorageaccount
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-key;EndpointSuffix=core.windows.net

# Signed URL expiry (seconds) - preview URLs
SIGNED_URL_EXPIRY_SECONDS=300

# Days before permanent deletion of soft-deleted documents
STORAGE_CLEANUP_DAYS=30

# ============================================================================
# EMAIL
# ============================================================================

# Email backend: smtp, sendgrid, or resend
EMAIL_PROVIDER=smtp

# For SMTP:
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_TLS=true

# For SendGrid (uncomment and fill in):
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.your-api-key-here

# For Resend (uncomment and fill in):
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_your-api-key-here

# Sender address (must be real domain for deliverability)
SMTP_FROM=noreply@vaultspace.local

# ============================================================================
# PREVIEW & DOCUMENT CONVERSION
# ============================================================================

# Preview provider: gotenberg or libreoffice
PREVIEW_PROVIDER=gotenberg

# Gotenberg service URL (must be Azure Container Apps sidecar or internal service)
GOTENBERG_URL=http://gotenberg:3000

# Preview timeout and limits
PREVIEW_TIMEOUT_SECONDS=60
PREVIEW_MAX_FILE_SIZE_MB=100

# ============================================================================
# VIRUS SCANNING
# ============================================================================

# Scan provider: clamav or none (never use none in production)
SCAN_PROVIDER=clamav

# ClamAV settings (must be Azure Container Apps sidecar or internal service)
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
SCAN_TIMEOUT_SECONDS=30

# ============================================================================
# SEARCH
# ============================================================================

# Search provider: postgres or meilisearch
SEARCH_PROVIDER=postgres

# Meilisearch settings (for SEARCH_PROVIDER=meilisearch)
# Note: If using Meilisearch, deploy as Azure Container Apps sidecar
# MEILISEARCH_URL=http://meilisearch:7700
# MEILISEARCH_API_KEY=your-api-key

# ============================================================================
# ENCRYPTION (V1 feature - NoOp in MVP)
# ============================================================================

# Encryption provider: noop, aes, or vault
ENCRYPTION_PROVIDER=noop

# AES encryption key (for ENCRYPTION_PROVIDER=aes)
# Generate with: openssl rand -base64 32
# ENCRYPTION_KEY=your-base64-encoded-key

# ============================================================================
# JOB QUEUE & WORKERS
# ============================================================================

# Enable background job queue
JOB_QUEUE_ENABLED=true

# Prefix for job queue keys in Redis
JOB_QUEUE_PREFIX=vaultspace

# Worker concurrency settings
JOB_QUEUE_CONCURRENCY=5
PREVIEW_WORKER_CONCURRENCY=2
SCAN_WORKER_CONCURRENCY=5
GENERAL_WORKER_CONCURRENCY=10

# Worker type (set via Docker environment)
# WORKER_TYPE=general

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================

# Monitoring provider: stdout or opentelemetry
MONITORING_PROVIDER=stdout

# OpenTelemetry settings (for MONITORING_PROVIDER=opentelemetry)
# OTEL_ENDPOINT=http://otel-collector:4317

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# V1 features (disabled in MVP)
FEATURE_SEARCH=false
FEATURE_WATERMARK=false
FEATURE_WEBHOOKS=false
FEATURE_ENCRYPTION=false
FEATURE_LEGAL_HOLD=false

# MVP features (enabled)
FEATURE_ANALYTICS=true
