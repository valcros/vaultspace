# VaultSpace — standalone (docker compose) environment
#
# Copy to .env and edit the values marked CHANGE_ME before running:
#   docker compose up -d
#
# The installer (scripts/setup.sh) generates this file automatically.
#
# docker-compose.yml constructs DATABASE_URL and REDIS_URL from the password
# variables below — do not set the full URLs here when using Compose.

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME

# ── Application ──────────────────────────────────────────────────────────────
DEPLOYMENT_MODE=standalone
NODE_ENV=production
APP_URL=http://localhost:3000
APP_NAME=VaultSpace
DEFAULT_ORG_NAME=My Organization
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────────────────────────────
# Compose sets POSTGRES_PASSWORD to this value and builds DATABASE_URL for containers.
# Generate with: openssl rand -hex 16
DATABASE_PASSWORD=CHANGE_ME
# DATABASE_PORT=5432   # uncomment to expose on a non-default host port

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
REDIS_PASSWORD=CHANGE_ME
# REDIS_PORT=6379      # uncomment to expose on a non-default host port

# ── Storage ──────────────────────────────────────────────────────────────────
# local | s3
STORAGE_PROVIDER=local
# STORAGE_LOCAL_PATH is fixed to /app/storage inside the Compose volume mount.

# S3-compatible storage (set STORAGE_PROVIDER=s3 and fill in)
# STORAGE_ENDPOINT=https://s3.amazonaws.com
# STORAGE_BUCKET=my-vaultspace-bucket
# STORAGE_KEY_ID=
# STORAGE_SECRET_KEY=
# STORAGE_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false    # set true for MinIO or path-style endpoints

# Signed URL expiry (seconds)
SIGNED_URL_EXPIRY_SECONDS=300

# ── Email ─────────────────────────────────────────────────────────────────────
# smtp | console   (console = print to stdout — dev/test only, no actual delivery)
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=false           # set true for TLS/SSL (port 465)
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ── Document preview ─────────────────────────────────────────────────────────
# gotenberg = full PDF/Office conversion   sharp = images only (no external service)
PREVIEW_ENGINE=gotenberg
# GOTENBERG_URL is set inside Compose to http://gotenberg:3000

# ── Virus scanning ────────────────────────────────────────────────────────────
# clamav = full scanning (recommended)   passthrough = disabled (not for production)
SCAN_ENGINE=clamav
# CLAMAV_HOST and CLAMAV_PORT are set inside Compose.

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=postgres

# ── Workers ───────────────────────────────────────────────────────────────────
# GENERAL_WORKER_CONCURRENCY=10
# PREVIEW_WORKER_CONCURRENCY=2
# SCAN_WORKER_CONCURRENCY=5
